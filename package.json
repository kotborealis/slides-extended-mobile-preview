{
  "name": "slides-extended-mobile-preview",
  "version": "0.7.0",
  "description": "Standalone Reveal.js preview for Markdown slide decks in Obsidian Mobile.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "lint": "eslint .",
    "test": "rm -rf .test-build && tsc -p tsconfig.test.json && node --test .test-build/**/*.test.js",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "revealjs",
    "slides",
    "mobile"
  ],
  "author": "kotborealis <kotborealis@awooo.ru>",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "obsidian": "^1.8.7",
    "reveal.js": "^6.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
